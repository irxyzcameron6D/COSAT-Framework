 RowBox[{
  RowBox[{"(*", 
   RowBox[{"COSAT", " ", "Duality", " ", "Saturation", " ", "Plot"}], "*)"}], 
  
  RowBox[{
   RowBox[{
    RowBox[{"criticalValue", "=", 
     RowBox[{"1", "-", 
      RowBox[{"1", "/", "GoldenRatio"}]}]}], ";"}], "\n", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"1", "-", 
