Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Nexus", " ", "Density", " ", "Flow", " ", "Simulation"}], "*)"}], 
  
  RowBox[{"VectorPlot3D", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "x"}], "/", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"x", "^", "2"}], "+", 
         RowBox[{"y", "^", "2"}], "+", 
         RowBox[{"z", "^", "2"}], "+", "0.5"}], ")"}]}], ",", 
      RowBox[{"-", "y"}], ",", 
      RowBox[{"-", "z"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"y", ",", 
      RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"z", ",", 
      RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
    RowBox[{"VectorStyle", "->", "\"\<Arrowhead\>\""}], ",", 
    RowBox[{"VectorPoints", "->", "Fine"}], ",", 
    RowBox[{
    "PlotLabel", 
     "->", "\"\<Heisenberg Pressure Gradient at Relativistic \
Velocity\>\""}]}], "]"}]}]], "Input",
